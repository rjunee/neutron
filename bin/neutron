#!/bin/sh
#
# neutron — the single-owner Open control CLI.
#
# A thin wrapper over neutron-service.sh (the boot/crash supervisor) + the
# data-backup helper. install.sh symlinks this onto your PATH so you can drive
# the server without remembering launchctl / systemctl incantations:
#
#   neutron start            start the server service
#   neutron stop             stop it (stays installed → boots next login)
#   neutron restart          restart it
#   neutron status           is it loaded/running?
#   neutron logs             tail the server log (Ctrl-C to stop)
#   neutron backup           run one data-backup pass now
#   neutron doctor           verify GBrain memory works (binary + round-trip)
#   neutron doctor --upgrade re-install latest GBrain if upstream advanced, then verify
#   neutron url              print the local chat URL
#
# The CLI resolves the checkout it belongs to from its own location (it lives at
# <code>/bin/neutron), so it works no matter where it is symlinked from. Every
# value the helpers need (data dir, port, bun) is re-resolved from <code>/.env.
#
# POSIX sh — no bashisms.

set -eu

# Resolve the real script path even when invoked through a symlink on PATH, so
# CODE_DIR is the checkout (<code>/bin/neutron) and not the symlink's dir.
resolve_self() {
  _p=$1
  while [ -L "$_p" ]; do
    _l=$(readlink "$_p")
    case "$_l" in
      /*) _p=$_l ;;
      *)  _p=$(dirname "$_p")/$_l ;;
    esac
  done
  printf '%s\n' "$_p"
}

SELF=$(resolve_self "$0")
BIN_DIR=$(CDPATH= cd -- "$(dirname -- "$SELF")" && pwd)
CODE_DIR=$(CDPATH= cd -- "$BIN_DIR/.." && pwd)
SERVICE="$CODE_DIR/neutron-service.sh"
BACKUP="$CODE_DIR/neutron-backup.sh"
DOCTOR="$CODE_DIR/gbrain-memory/gbrain-doctor.ts"
DIAGNOSTICS="$CODE_DIR/open/diagnostics-cli.ts"

NEUTRON_SERVICE_CODE_DIR=$CODE_DIR
export NEUTRON_SERVICE_CODE_DIR

# Optional Neutron-themed color for the human-facing usage banner only. Gated on
# a TTY with NO_COLOR unset / TERM not dumb, so machine-readable output (`url`)
# and piped/CI runs stay plain. Empty vars in the non-fancy case.
_esc=$(printf '\033')
if [ -t 1 ] && [ -z "${NO_COLOR:-}" ] && [ "${TERM:-}" != dumb ]; then
  _B="${_esc}[1m${_esc}[38;5;141m"; _M="${_esc}[38;5;245m"; _R="${_esc}[0m"
else
  _B=''; _M=''; _R=''
fi

# Resolve the chat URL port the same way the server does (NEUTRON_PORT env/.env,
# else 7800) for `neutron url`.
_port() {
  _p=${NEUTRON_PORT:-}
  if [ -z "$_p" ] && [ -f "$CODE_DIR/.env" ]; then
    _line=$(grep -E '^[[:space:]]*(export[[:space:]]+)?NEUTRON_PORT=' "$CODE_DIR/.env" 2>/dev/null | tail -n1)
    _p=${_line#*=}
    # Strip one surrounding pair of quotes, the way Bun's .env loader does, so a
    # pinned NEUTRON_PORT="7800" / '7800' yields a bare 7800 for the URL.
    case "$_p" in
      \"*\") _p=${_p#\"}; _p=${_p%\"} ;;
      \'*\') _p=${_p#\'}; _p=${_p%\'} ;;
    esac
  fi
  [ -n "$_p" ] || _p=7800
  printf '%s\n' "$_p"
}

cmd=${1:-}
case "$cmd" in
  start|stop|restart|status|logs|install|uninstall)
    [ -f "$SERVICE" ] || { printf 'neutron: service helper missing at %s\n' "$SERVICE" >&2; exit 1; }
    exec sh "$SERVICE" "$cmd" ;;
  backup)
    [ -f "$BACKUP" ] || { printf 'neutron: backup helper missing at %s\n' "$BACKUP" >&2; exit 1; }
    exec sh "$BACKUP" run ;;
  doctor)
    # GBrain memory health-check + auto-upgrade (the cc-update-doctor analogue).
    #   neutron doctor              verify gbrain works (binary, responds, round-trip)
    #   neutron doctor --upgrade    re-install latest upstream if advanced, then verify
    # Runs the deterministic TS doctor (gbrain-memory/gbrain-doctor.ts) via bun.
    shift
    [ -f "$DOCTOR" ] || { printf 'neutron: doctor helper missing at %s\n' "$DOCTOR" >&2; exit 1; }
    _bun=${BUN_BIN:-$(command -v bun 2>/dev/null || true)}
    [ -n "$_bun" ] || { printf 'neutron: bun not found — cannot run the gbrain doctor (set BUN_BIN or install bun)\n' >&2; exit 1; }
    # Translate the user-facing `--upgrade` flag into the doctor's `upgrade`
    # subcommand; default (no flag) is the read-only `check`. Remaining flags
    # (--json / --force) pass straight through.
    _sub=check
    _rest=""
    _json=0
    for _a in "$@"; do
      case "$_a" in
        --upgrade) _sub=upgrade ;;
        --json) _json=1; _rest="$_rest $_a" ;;
        *) _rest="$_rest $_a" ;;
      esac
    done
    if [ "$_sub" = check ]; then
      # Read-only verify path: run the GBrain memory checks, then (O5) print the
      # broader diagnostics surface (chat/import/cron/events/credentials) so
      # "why is X broken?" is answerable without journalctl. The diagnostics
      # printer is best-effort and NEVER flips the doctor's exit code.
      _rc=0
      # shellcheck disable=SC2086
      "$_bun" run "$DOCTOR" check $_rest || _rc=$?
      # Only append the human diagnostics dump in TEXT mode. Under --json the
      # doctor already emits ONE machine-readable document; a second JSON object
      # would break `neutron doctor --json | jq .` (query the live instance's
      # GET /api/app/admin/diagnostics for JSON diagnostics instead).
      if [ "$_json" = 0 ] && [ -f "$DIAGNOSTICS" ]; then
        "$_bun" run "$DIAGNOSTICS" || true
      fi
      exit "$_rc"
    fi
    # --upgrade path: re-install + verify only (no diagnostics dump).
    # shellcheck disable=SC2086
    exec "$_bun" run "$DOCTOR" "$_sub" $_rest ;;
  url)
    printf 'http://127.0.0.1:%s/chat\n' "$(_port)" ;;
  ""|--help|-h)
    if [ "$_B" != "" ]; then
      printf '%s⚛ neutron%s  %sthe single-owner Open control CLI%s\n' "$_B" "$_R" "$_M" "$_R"
    fi
    printf 'usage: neutron {start|stop|restart|status|logs|backup|doctor|url}\n' ;;
  *)
    printf 'neutron: unknown command: %s (try --help)\n' "$cmd" >&2; exit 1 ;;
esac
