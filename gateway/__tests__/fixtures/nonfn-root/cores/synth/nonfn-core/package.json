        "output_schema": { "type": "object" },
        "capability_required": "read:project_data"
      }
    ],
    "ui_components": [],
    "billing_hooks": [],
    "linked_sources": [],
    "secrets": [],
    "compat": { "coreApi": "^1.0.0" },
    "build": { "neutronVersion": "0.1.0" }
  }
}
