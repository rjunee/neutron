# Neutron (Open) — example environment.
#
# Copy to `.env` (`cp .env.example .env`) and edit. Every value below has a
# sane built-in default, so the gateway boots with an empty file; the entries
# here are the knobs a self-hoster most often wants to set. Use real values in
# your own `.env` — never commit it.

# --- Where Neutron keeps its state -----------------------------------------

# Base directory for Neutron's data (auth, registry, the project DB — the dir
# the git backup protects). Use an absolute path — Bun does NOT expand a leading
# `~` in .env values (it would create a literal `~` directory), but it DOES
# expand `$HOME`. install.sh pins this to ~/neutron/data; code lives separately
# at ~/neutron/core (single ~/neutron umbrella).
NEUTRON_HOME=$HOME/neutron/data

# Override the SQLite database file. Same `$HOME` (not `~`) rule applies.
# Default when unset: $NEUTRON_HOME/project.db (i.e. $HOME/neutron/data/project.db).
# install.sh migrates whatever path resolves here, so it always matches the
# database the server opens.
# NEUTRON_DB_PATH=$HOME/neutron/data/project.db

# --- How the gateway listens -----------------------------------------------

# HTTP port for the gateway + bundled web chat. Default: 7800
NEUTRON_PORT=7800

# Bind address for the gateway. Default: 127.0.0.1 (loopback only).
# Loopback keeps the gateway off your LAN while it is still unauthenticated.
# Set 0.0.0.0 to expose it on all interfaces — only behind a trusted network
# (or once the auth gate ships fail-closed). See the Open README's exposure
# warning before widening this.
# NEUTRON_HOST=127.0.0.1

# --- How Neutron reaches Claude --------------------------------------------
#
# Neutron spawns the `claude` CLI as its LLM substrate. Authenticate it with
# EITHER a Claude subscription token OR an Anthropic API key. The subscription
# route is preferred — run `claude setup-token` and paste the result, or paste
# it during onboarding in chat.

# Claude subscription OAuth token (output of `claude setup-token`).
CLAUDE_CODE_OAUTH_TOKEN=

# Or an API key, if you bill via the Anthropic API instead of a subscription.
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# Path to the `claude` binary, if it is not on PATH. Default: claude
# CLAUDE_BIN=claude

# --- Telegram (optional) ----------------------------------------------------
#
# The bundled web chat works with no Telegram setup. To also message Neutron
# from Telegram, create a bot with @BotFather and set its username here; you
# paste the bot token during onboarding in chat.
# NEUTRON_TELEGRAM_BOT=my_neutron_bot

# Your Telegram supergroup chat id (the negative number @BotFather-style bots
# see for a forum group, e.g. -1001234567890). Reminder + topic agent prompts
# resolve `{{TELEGRAM_CHAT_ID}}` from this value at fire time, so set it to the
# group Neutron posts into. Left unset, prompts render a clear
# `<telegram-chat-id-unset>` placeholder instead of any real chat id.
# TELEGRAM_CHAT_ID=-1001234567890

# --- Owner session (recommended) -------------------------------------------
#
# Secret that signs the owner's onboarding/chat session cookie. install.sh
# auto-generates a stable value here at install time so your logged-in session
# SURVIVES server restarts. If left unset, the server mints a fresh random
# secret on every boot — which silently logs you out on each restart. Set/keep a
# stable value (any long random string) to persist sessions.
# NEUTRON_ONBOARDING_CHAT_COOKIE_SECRET=

# --- Model overrides (optional) --------------------------------------------

# Best/most-capable model. Default: claude-opus-4-7
# NEUTRON_BEST_MODEL=claude-opus-4-7

# Fast/cheap model. Default: claude-haiku-4-5-20251001
# NEUTRON_FAST_MODEL=claude-haiku-4-5-20251001

# --- Data backups (optional) -----------------------------------------------
#
# install.sh schedules a deterministic, no-LLM git backup of NEUTRON_HOME (the
# data dir) on a timer. With no remote, local git history alone is recoverable.

# Seconds between backups. Default: 43200 (12h).
# NEUTRON_BACKUP_INTERVAL=43200

# Git remote URL for OFFSITE backup pushes. When set, each backup also pushes
# (e.g. a private GitHub repo). Unset → local git history only. install.sh also
# accepts this as `--backup-remote <url>`, persists it here, and wires it into
# the backup timer so the scheduled push actually targets it.
# NEUTRON_BACKUP_REMOTE=git@github.com:you/neutron-backup.git
