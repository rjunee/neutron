{
  "name": "@neutronai/tasks-core",
  "version": "0.2.0",
  "type": "module",
  "main": "./index.ts",
  "exports": {
    ".": "./index.ts",
    "./manifest": "./src/manifest.ts",
    "./backend": "./src/backend.ts",
    "./tools": "./src/tools.ts",
    "./chat-commands": "./src/chat-commands.ts",
    "./pick-next": "./src/pick-next.ts",
    "./mcp-tools-extra": "./src/mcp-tools-extra.ts"
  },
  "private": true,
  "dependencies": {
    "@neutronai/auth": "workspace:*",
    "@neutronai/cores-runtime": "workspace:*",
    "@neutronai/cores-sdk": "workspace:*",
    "@neutronai/migrations": "workspace:*",
    "@neutronai/persistence": "workspace:*",
    "@neutronai/tasks": "workspace:*"
  },
  "neutron": {
    "capabilities": [
      "read:tasks_core.db",
      "write:tasks_core.db"
    ],
    "tier_support": [
      "regular"
    ],
    "tools": [
      {
        "name": "tasks_create",
        "description": "Create a new task. Returns the assigned task id and the full task row.",
        "input_schema": {
          "type": "object",
          "properties": {
            "title": {
              "type": "string",
              "description": "Task title — short imperative phrase."
            },
            "due_date": {
              "type": "string",
              "description": "Optional ISO-8601 date or datetime the task is due."
            },
            "priority": {
              "type": "integer",
              "description": "Optional priority on the canonical 0-3 scale (3 = most urgent, 0 = lowest)."
            },
            "project_id": {
              "type": "string",
              "description": "Optional project scope for owners with multiple projects."
            }
          },
          "required": [
            "title"
          ]
        },
        "output_schema": {
          "type": "object",
          "properties": {
            "id": {
              "type": "string"
            },
            "task": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string"
                },
                "title": {
                  "type": "string"
                },
                "status": {
                  "type": "string"
                },
                "created_at": {
                  "type": "number"
                },
                "updated_at": {
                  "type": "number"
                }
              },
              "required": [
                "id",
                "title",
                "status",
                "created_at",
                "updated_at"
              ]
            }
          },
          "required": [
            "id",
            "task"
          ]
        },
        "capability_required": "write:tasks_core.db"
      },
      {
        "name": "tasks_list",
        "description": "List tasks, newest-first. Optional project_id narrows to a single project; status defaults to 'open' (excludes completed).",
        "input_schema": {
          "type": "object",
          "properties": {
            "project_id": {
              "type": "string",
              "description": "Optional project scope."
            },
            "status": {
              "type": "string",
              "enum": [
                "open",
                "done",
                "all"
              ],
              "description": "Filter by status. Default 'open'."
            },
            "limit": {
              "type": "integer",
              "description": "Maximum number of rows to return. Backend default applies when omitted."
            }
          }
        },
        "output_schema": {
          "type": "object",
          "properties": {
            "results": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "id": {
                    "type": "string"
                  },
                  "title": {
                    "type": "string"
                  },
                  "status": {
                    "type": "string"
                  },
                  "due_date": {
                    "type": "string"
                  },
                  "priority": {
                    "type": "integer"
                  },
                  "project_id": {
                    "type": "string"
                  },
                  "created_at": {
                    "type": "number"
                  },
                  "updated_at": {
                    "type": "number"
                  },
                  "completed_at": {
                    "type": "number"
                  }
                },
                "required": [
                  "id",
                  "title",
                  "status",
                  "created_at",
                  "updated_at"
                ]
              }
            }
          },
          "required": [
            "results"
          ]
        },
        "capability_required": "read:tasks_core.db"
      },
      {
        "name": "tasks_update",
        "description": "Update one or more fields on an existing task. Returns the full updated task row.",
        "input_schema": {
          "type": "object",
          "properties": {
            "task_id": {
              "type": "string",
              "description": "Id of the task to update."
            },
            "fields": {
              "type": "object",
              "properties": {
                "title": {
                  "type": "string"
                },
                "due_date": {
                  "type": "string"
                },
                "priority": {
                  "type": "integer"
                },
                "project_id": {
                  "type": "string"
                },
                "status": {
                  "type": "string",
                  "enum": [
                    "open",
                    "done"
                  ]
                }
              }
            }
          },
          "required": [
            "task_id",
            "fields"
          ]
        },
        "output_schema": {
          "type": "object",
          "properties": {
            "task": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string"
                },
                "title": {
                  "type": "string"
                },
                "status": {
                  "type": "string"
                },
                "created_at": {
                  "type": "number"
                },
                "updated_at": {
                  "type": "number"
                }
              },
              "required": [
                "id",
                "title",
                "status",
                "created_at",
                "updated_at"
              ]
            }
          },
          "required": [
            "task"
          ]
        },
        "capability_required": "write:tasks_core.db"
      },
      {
        "name": "tasks_complete",
        "description": "Mark a task complete. Stamps status='done' and completed_at on the row.",
        "input_schema": {
          "type": "object",
          "properties": {
            "task_id": {
              "type": "string",
              "description": "Id of the task to complete."
            }
          },
          "required": [
            "task_id"
          ]
        },
        "output_schema": {
          "type": "object",
          "properties": {
            "task": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string"
                },
                "title": {
                  "type": "string"
                },
                "status": {
                  "type": "string"
                },
                "completed_at": {
                  "type": "number"
                }
              },
              "required": [
                "id",
                "title",
                "status",
                "completed_at"
              ]
            }
          },
          "required": [
            "task"
          ]
        },
        "capability_required": "write:tasks_core.db"
      },
      {
        "name": "tasks_delete",
        "description": "Delete a task by id. Returns {ok: true, task_id} on success.",
        "input_schema": {
          "type": "object",
          "properties": {
            "task_id": {
              "type": "string",
              "description": "Id of the task to delete."
            }
          },
          "required": [
            "task_id"
          ]
        },
        "output_schema": {
          "type": "object",
          "properties": {
            "ok": {
              "type": "boolean",
              "const": true
            },
            "task_id": {
              "type": "string"
            }
          },
          "required": [
            "ok",
            "task_id"
          ]
        },
        "capability_required": "write:tasks_core.db"
      },
      {
        "name": "tasks_pick_next",
        "description": "LLM-driven pick-next: returns the one open task to do RIGHT NOW with a short owner-voice rationale and up to N runner-up alternatives. Reads only — does not mutate any row.",
        "input_schema": {
          "type": "object",
          "properties": {
            "project_id": {
              "type": "string",
              "description": "Optional. Omit for cross-project; pass to narrow to one project."
            },
            "limit_alternatives": {
              "type": "integer",
              "description": "Optional runner-up count surfaced alongside the chosen candidate. Default 3, cap 5."
            }
          }
        },
        "output_schema": {
          "type": "object",
          "properties": {
            "candidate": {
              "anyOf": [
                {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "string"
                    },
                    "title": {
                      "type": "string"
                    },
                    "status": {
                      "type": "string"
                    },
                    "created_at": {
                      "type": "number"
                    },
                    "updated_at": {
                      "type": "number"
                    }
                  },
                  "required": [
                    "id",
                    "title",
                    "status",
                    "created_at",
                    "updated_at"
                  ]
                },
                {
                  "type": "null"
                }
              ]
            },
            "rationale": {
              "type": "string"
            },
            "alternatives": {
              "type": "array"
            },
            "audit": {
              "type": "object",
              "properties": {
                "candidates_considered": {
                  "type": "integer"
                },
                "focus_score_used": {
                  "type": "boolean"
                },
                "llm_model": {
                  "type": "string"
                }
              },
              "required": [
                "candidates_considered",
                "focus_score_used",
                "llm_model"
              ]
            }
          },
          "required": [
            "candidate",
            "rationale",
            "alternatives",
            "audit"
          ]
        },
        "capability_required": "read:tasks_core.db"
      }
    ],
    "ui_components": [
      {
        "name": "TasksLauncherIcon",
        "entry_point": "./src/ui/launcher-icon.ts",
        "surface": "launcher_icon"
      },
      {
        "name": "TasksAppTab",
        "entry_point": "./src/ui/app-tab-surface.ts",
        "surface": "app_tab",
        "props_schema": {
          "type": "object",
          "properties": {
            "path": {
              "type": "string",
              "const": "/projects/<project_id>/tasks"
            },
            "label": {
              "type": "string",
              "const": "Tasks"
            },
            "emoji": {
              "type": "string",
              "const": "✅"
            },
            "order": {
              "type": "integer",
              "const": 30
            }
          },
          "required": [
            "path",
            "label",
            "emoji",
            "order"
          ]
        }
      }
    ],
    "billing_hooks": [],
    "linked_sources": [],
    "secrets": [],
    "compat": {
      "coreApi": "^0.1.0"
    },
    "build": {
      "neutronVersion": "0.2.0"
    }
  }
}
