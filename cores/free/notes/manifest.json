{
  "capabilities": [
    "read:notes.db",
    "write:notes.db",
    "read:notes.fts",
    "write:notes.fts"
  ],
  "tier_support": [
    "regular"
  ],
  "tools": [
    {
      "name": "notes_write",
      "description": "Persist a note in the user's second-brain. Returns the assigned note id.",
      "input_schema": {
        "type": "object",
        "properties": {
          "content": {
            "type": "string",
            "description": "The note body — plain text or markdown."
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Optional tags stored on the note's metadata."
          },
          "project_id": {
            "type": "string",
            "description": "Optional project scope; defaults to the caller's active project."
          }
        },
        "required": [
          "content"
        ]
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          }
        },
        "required": [
          "id"
        ]
      },
      "capability_required": "write:notes.db"
    },
    {
      "name": "notes_recall",
      "description": "Semantic / textual recall against the user's second-brain. Returns the top matches ranked by backend-assigned score.",
      "input_schema": {
        "type": "object",
        "properties": {
          "query": {
            "type": "string",
            "description": "Search query — natural language or keywords."
          },
          "limit": {
            "type": "integer",
            "description": "Maximum number of matches to return. Backend default applies when omitted."
          },
          "project_id": {
            "type": "string",
            "description": "Optional project scope."
          }
        },
        "required": [
          "query"
        ]
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "results": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string"
                },
                "content": {
                  "type": "string"
                },
                "score": {
                  "type": "number"
                },
                "metadata": {
                  "type": "object"
                }
              },
              "required": [
                "id",
                "content",
                "score",
                "metadata"
              ]
            }
          }
        },
        "required": [
          "results"
        ]
      },
      "capability_required": "read:notes.db"
    },
    {
      "name": "notes_list",
      "description": "List recent notes. Optional project_id filter narrows to a single project's notes; backends that don't index project_id ignore the filter.",
      "input_schema": {
        "type": "object",
        "properties": {
          "limit": {
            "type": "integer",
            "description": "Maximum number of notes to return. Backend default applies when omitted."
          },
          "project_id": {
            "type": "string",
            "description": "Optional project scope for owners with multiple projects."
          }
        }
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "results": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string"
                },
                "content": {
                  "type": "string"
                },
                "score": {
                  "type": "number"
                },
                "metadata": {
                  "type": "object"
                }
              },
              "required": [
                "id",
                "content",
                "score",
                "metadata"
              ]
            }
          }
        },
        "required": [
          "results"
        ]
      },
      "capability_required": "read:notes.db"
    },
    {
      "name": "notes_link",
      "description": "Create a directed link from one note to another. Persisted as a KG edge (kind='user_tunnel') in the per-project sidecar.",
      "input_schema": {
        "type": "object",
        "properties": {
          "source_id": {
            "type": "string",
            "description": "Origin note id."
          },
          "target_id": {
            "type": "string",
            "description": "Destination note id."
          },
          "project_id": {
            "type": "string",
            "description": "Optional project scope."
          }
        },
        "required": [
          "source_id",
          "target_id"
        ]
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "ok": {
            "type": "boolean",
            "const": true
          },
          "link_id": {
            "type": "string"
          }
        },
        "required": [
          "ok",
          "link_id"
        ]
      },
      "capability_required": "write:notes.db"
    },
    {
      "name": "notes_create_drawer",
      "description": "Create a drawer in the project's Notes sidecar. Idempotent on name — returns the existing drawer if one with the same name already exists.",
      "input_schema": {
        "type": "object",
        "properties": {
          "project_id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "kind": {
            "type": "string",
            "enum": [
              "inbox",
              "pinned",
              "archive",
              "custom"
            ]
          }
        },
        "required": [
          "project_id",
          "name"
        ]
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          }
        },
        "required": [
          "id"
        ]
      },
      "capability_required": "write:notes.db"
    },
    {
      "name": "notes_drawer_list",
      "description": "List drawers in the project's Notes sidecar, with note counts.",
      "input_schema": {
        "type": "object",
        "properties": {
          "project_id": {
            "type": "string"
          }
        },
        "required": [
          "project_id"
        ]
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "drawers": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string"
                },
                "name": {
                  "type": "string"
                },
                "kind": {
                  "type": "string"
                },
                "note_count": {
                  "type": "integer"
                }
              },
              "required": [
                "id",
                "name",
                "kind",
                "note_count"
              ]
            }
          }
        },
        "required": [
          "drawers"
        ]
      },
      "capability_required": "read:notes.db"
    },
    {
      "name": "notes_search",
      "description": "Hybrid lex + vec + KG-traverse search over the project's notes. v1 ships lex (FTS5 BM25) + a deterministic-rank vec stub.",
      "input_schema": {
        "type": "object",
        "properties": {
          "project_id": {
            "type": "string"
          },
          "query": {
            "type": "string"
          },
          "limit": {
            "type": "integer"
          }
        },
        "required": [
          "project_id",
          "query"
        ]
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "results": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "note_id": {
                  "type": "string"
                },
                "drawer_id": {
                  "type": "string"
                },
                "snippet": {
                  "type": "string"
                },
                "score": {
                  "type": "number"
                },
                "why": {
                  "type": "string"
                },
                "updated_at": {
                  "type": "integer"
                }
              },
              "required": [
                "note_id",
                "drawer_id",
                "snippet",
                "score",
                "why",
                "updated_at"
              ]
            }
          }
        },
        "required": [
          "results"
        ]
      },
      "capability_required": "read:notes.fts"
    },
    {
      "name": "notes_traverse",
      "description": "BFS-traverse the project's KG up to depth 3 starting at a note id. Returns the visited nodes + edges.",
      "input_schema": {
        "type": "object",
        "properties": {
          "project_id": {
            "type": "string"
          },
          "from": {
            "type": "string"
          },
          "depth": {
            "type": "integer",
            "minimum": 1,
            "maximum": 3
          }
        },
        "required": [
          "project_id",
          "from"
        ]
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "nodes": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "edges": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        },
        "required": [
          "nodes",
          "edges"
        ]
      },
      "capability_required": "read:notes.db"
    }
  ],
  "ui_components": [
    {
      "name": "NotesLauncherIcon",
      "entry_point": "./src/ui/launcher-icon.ts",
      "surface": "launcher_icon"
    },
    {
      "name": "NotesAppTab",
      "entry_point": "./src/ui/drawer-browser-surface.ts",
      "surface": "app_tab",
      "props_schema": {
        "type": "object",
        "properties": {
          "path": {
            "type": "string"
          },
          "label": {
            "type": "string"
          },
          "emoji": {
            "type": "string"
          }
        }
      }
    }
  ],
  "billing_hooks": [],
  "linked_sources": [],
  "secrets": [],
  "compat": {
    "coreApi": "^0.1.0"
  },
  "build": {
    "neutronVersion": "0.1.0"
  }
}
