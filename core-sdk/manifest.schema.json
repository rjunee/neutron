{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://neutron.example/schemas/core-manifest-v1.json",
  "title": "Neutron Core Manifest",
  "description": "Shape of the \"neutron\" section in a Core's package.json (Sprint 2B P0 stub). Mirrors core-sdk/types.ts NeutronManifest. Adding a capability is a 4-place edit (types.ts union, validator.ts KNOWN_CAPABILITIES, this enum, validator.test.ts).",
  "type": "object",
  "required": [
    "capabilities",
    "tier_support",
    "tools",
    "ui_components",
    "billing_hooks",
    "linked_sources",
    "secrets",
    "compat",
    "build"
  ],
  "properties": {
    "capabilities": {
      "type": "array",
      "items": { "$ref": "#/$defs/NeutronCapability" }
    },
    "tier_support": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/TierSupport" }
    },
    "tools": {
      "type": "array",
      "items": { "$ref": "#/$defs/ToolDef" }
    },
    "ui_components": {
      "type": "array",
      "items": { "$ref": "#/$defs/UiComponentDef" }
    },
    "billing_hooks": {
      "type": "array",
      "items": { "$ref": "#/$defs/BillingHookDef" }
    },
    "linked_sources": {
      "type": "array",
      "items": { "$ref": "#/$defs/LinkedSourceDef" }
    },
    "secrets": {
      "type": "array",
      "items": { "$ref": "#/$defs/ManifestSecret" }
    },
    "compat": {
      "type": "object",
      "required": ["coreApi"],
      "properties": {
        "coreApi": {
          "type": "string",
          "description": "Semver range, canonical npm-style grammar: `*` (anywhere a clause is allowed, including inside `||` unions), single term, space-joined intersections (whitespace between comparator and version is permitted), or `||`-joined unions. Mirror of validator.ts isValidSemverRange — keep the two in sync; validator.test.ts round-trip suite enforces parity.",
          "pattern": "^\\s*((\\*|([\\^~]|>=?|<=?|=)?\\s*\\d+(\\.\\d+){0,2}(-[0-9A-Za-z.-]+)?(\\+[0-9A-Za-z.-]+)?(\\s+([\\^~]|>=?|<=?|=)?\\s*\\d+(\\.\\d+){0,2}(-[0-9A-Za-z.-]+)?(\\+[0-9A-Za-z.-]+)?)*)(\\s*\\|\\|\\s*(\\*|([\\^~]|>=?|<=?|=)?\\s*\\d+(\\.\\d+){0,2}(-[0-9A-Za-z.-]+)?(\\+[0-9A-Za-z.-]+)?(\\s+([\\^~]|>=?|<=?|=)?\\s*\\d+(\\.\\d+){0,2}(-[0-9A-Za-z.-]+)?(\\+[0-9A-Za-z.-]+)?)*))*)\\s*$"
        }
      }
    },
    "build": {
      "type": "object",
      "required": ["neutronVersion"],
      "properties": {
        "neutronVersion": { "type": "string", "minLength": 1 }
      }
    }
  },
  "$defs": {
    "NeutronCapability": {
      "type": "string",
      "enum": [
        "read:gmail",
        "write:gmail",
        "read:calendar",
        "write:calendar",
        "read:tasks",
        "write:tasks",
        "read:docs",
        "write:docs",
        "read:project_data",
        "write:project_data",
        "read:memory",
        "write:memory",
        "read:project.db",
        "write:project.db",
        "network:external",
        "network:github",
        "network:browse",
        "fs:project_data",
        "fs:cache",
        "host:gh",
        "agent:dispatch_subagent",
        "mcp:tool_register"
      ]
    },
    "TierSupport": {
      "type": "string",
      "enum": ["regular", "private", "both"]
    },
    "ToolDef": {
      "type": "object",
      "required": ["name", "description", "input_schema", "output_schema", "capability_required"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "input_schema": { "type": "object" },
        "output_schema": { "type": "object" },
        "capability_required": { "$ref": "#/$defs/NeutronCapability" }
      }
    },
    "UiComponentDef": {
      "type": "object",
      "required": ["name", "entry_point", "surface"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "entry_point": { "type": "string", "minLength": 1 },
        "surface": {
          "type": "string",
          "enum": ["launcher_icon", "project_tab", "settings_panel", "route_mount", "app_tab"]
        },
        "mount_path": { "type": "string", "minLength": 1 },
        "props_schema": { "type": "object" }
      },
      "allOf": [
        {
          "if": {
            "properties": { "surface": { "const": "route_mount" } },
            "required": ["surface"]
          },
          "then": { "required": ["mount_path"] }
        }
      ]
    },
    "BillingHookDef": {
      "type": "object",
      "required": ["model", "price_cents", "currency"],
      "properties": {
        "model": {
          "type": "string",
          "enum": ["flat_monthly", "usage_metered", "one_time"]
        },
        "price_cents": { "type": "number" },
        "currency": { "type": "string", "minLength": 1 },
        "on_install": { "type": "string" },
        "on_uninstall": { "type": "string" }
      }
    },
    "LinkedSourceDef": {
      "type": "object",
      "required": ["kind", "scope", "target_kinds"],
      "properties": {
        "kind": {
          "type": "string",
          "minLength": 1,
          "description": "Free-form provider id per § A.3.5 (sprint 24). Topline's dtc-analytics declares 'shopify', 'google-ads', etc.; the closed enum that previously gated this field is now informational only — see KNOWN_LINKED_SOURCE_KINDS in core-sdk/validator.ts."
        },
        "scope": {
          "type": "string",
          "enum": ["read", "read_write"]
        },
        "target_kinds": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["user", "workspace"]
          }
        }
      }
    },
    "ManifestSecret": {
      "type": "object",
      "required": ["name", "kind", "label", "required", "install_prompt"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "kind": {
          "type": "string",
          "enum": ["byo_api_key", "oauth_token", "oauth_client", "webhook_secret"]
        },
        "label": { "type": "string", "minLength": 1 },
        "scope": { "type": "string", "minLength": 1 },
        "required": { "type": "boolean" },
        "install_prompt": { "type": "string", "minLength": 1 }
      }
    }
  }
}
