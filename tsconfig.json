{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    // The deploy gate runs `bunx tsc --noEmit` against this root config over the
    // SERVER tree. No "DOM" here on purpose (G5): server code must NOT typecheck
    // against browser globals like `document`/`window` — that masks wrong-runtime
    // bugs. Browser leaves own their own DOM lib and their own `tsc -p` step in
    // the CI matrix: `landing/` (landing/tsconfig.json), `landing/chat-react/`,
    // `chat-core/`, `app/`. The server-side landing modules that server code
    // imports (session-cookie, spa-routes, server type surface) are DOM-free.
    "lib": ["ESNext"]
  },
  "include": [
    "open/**/*.ts",
    "gateway/**/*.ts",
    "runtime/**/*.ts",
    "scribe/**/*.ts",
    "reflection/**/*.ts",
    "gbrain-memory/**/*.ts",
    "reminders/**/*.ts",
    "tasks/**/*.ts",
    "skill-forge/**/*.ts",
    "tabs/**/*.ts",
    "cron/**/*.ts",
    "doc-search/**/*.ts",
    "message-search/**/*.ts",
    "cores/**/*.ts",
    "prompts/**/*.ts",
    "mcp/**/*.ts",
    "tools/**/*.ts",
    "migrations/**/*.ts",
    "persistence/**/*.ts",
    "chat-core/**/*.ts",
    "tests/integration/**/*.ts",
    "tests/support/**/*.ts",
    "tests/fixtures/**/*.ts",
    "scripts/**/*.ts",
    "core-sdk/**/*.ts",
    "channels/**/*.ts",
    "connect/**/*.ts",
    "watchdog/**/*.ts",
    "auth/**/*.ts",
    "onboarding/**/*.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
